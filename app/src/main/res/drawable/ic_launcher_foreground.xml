<svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#2D2419"/>
      <stop offset="100%" stop-color="#1A1410"/>
    </linearGradient>
    <linearGradient id="wood" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#E8A855"/>
      <stop offset="100%" stop-color="#C9812F"/>
    </linearGradient>
    <linearGradient id="woodShine" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#F4C077"/>
      <stop offset="100%" stop-color="#D9954A"/>
    </linearGradient>
  </defs>

  <!-- App icon background -->
  <rect x="0" y="0" width="512" height="512" rx="108" fill="url(#bg)"/>

  <!-- Subtle inner shadow ring for depth -->
  <rect x="0" y="0" width="512" height="512" rx="108" fill="none" stroke="#000000" stroke-opacity="0.25" stroke-width="2"/>

  <!-- The letter S built from 4 stacked "shelf" bars/planks -->
  <!-- Top shelf plank (top of S) -->
  <rect x="120" y="112" width="272" height="56" rx="14" fill="url(#woodShine)"/>
  <rect x="120" y="112" width="272" height="14" rx="7" fill="#FBDBA0" opacity="0.6"/>
  <!-- side pegs suggesting shelf brackets -->
  <circle cx="146" cy="140" r="6" fill="#8A5A22"/>
  <circle cx="366" cy="140" r="6" fill="#8A5A22"/>

  <!-- Upper-left vertical connector -->
  <rect x="120" y="168" width="56" height="96" rx="14" fill="url(#wood)"/>

  <!-- Middle shelf plank -->
  <rect x="120" y="228" width="272" height="56" rx="14" fill="url(#woodShine)"/>
  <rect x="120" y="228" width="272" height="14" rx="7" fill="#FBDBA0" opacity="0.6"/>
  <circle cx="146" cy="256" r="6" fill="#8A5A22"/>
  <circle cx="366" cy="256" r="6" fill="#8A5A22"/>

  <!-- Lower-right vertical connector -->
  <rect x="336" y="248" width="56" height="96" rx="14" fill="url(#wood)"/>

  <!-- Bottom shelf plank -->
  <rect x="120" y="344" width="272" height="56" rx="14" fill="url(#woodShine)"/>
  <rect x="120" y="344" width="272" height="14" rx="7" fill="#FBDBA0" opacity="0.6"/>
  <circle cx="146" cy="372" r="6" fill="#8A5A22"/>
  <circle cx="366" cy="372" r="6" fill="#8A5A22"/>

  <!-- small items resting on shelves to reinforce "shelf" concept -->
  <rect x="200" y="184" width="14" height="44" rx="3" fill="#E4572E"/>
  <rect x="222" y="192" width="14" height="36" rx="3" fill="#3E8E7E"/>
  <rect x="270" y="300" width="14" height="44" rx="3" fill="#3E8E7E"/>
  <rect x="292" y="308" width="14" height="36" rx="3" fill="#E4572E"/>

</svg>
